---
import { getProductById, getAllProducts } from '../../data/products.js';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductDetailWithCart from '../../components/ProductDetailWithCart.jsx';

export async function getStaticPaths() {
  const allProducts = await getAllProducts();
  return allProducts.map(product => {
    // Obtener relacionados: misma categoría, excluyendo el actual
    const relatedProducts = allProducts
      .filter(p => p.category === product.category && p.id !== product.id)
      .slice(0, 4);

    return {
      params: { id: product.id.toString() },
      props: { product, relatedProducts }
    };
  });
}

interface Props {
  product: any;
  relatedProducts: any[];
}

const { product, relatedProducts } = Astro.props as Props;

if (!product) {
  return Astro.redirect('/');
}
---

<BaseLayout title={`${product.title} | Giopromet`} description={product.description}>
  <ProductDetailWithCart client:load product={product} relatedProducts={relatedProducts} />
</BaseLayout>

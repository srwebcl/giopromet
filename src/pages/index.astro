---
import Prototipo from '../components/Prototipo.jsx';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllProducts } from '../data/products.js';

const allProducts = await getAllProducts();

// Seleccionar productos para las secciones
// 1. Hero: Productos con categoría "heroe"
const heroProducts = allProducts.filter(p => p.categorySlugs?.includes('heroe'));

// Fallback si no hay productos "heroe"
const finalHeroProducts = heroProducts.length > 0 
  ? heroProducts 
  : [allProducts.find(p => p.featured) || allProducts[0]];

const trendingProducts = allProducts.filter(p => p.categorySlugs?.includes('tendencias')).slice(0, 8);
const viralProducts = allProducts.filter(p => p.categorySlugs?.includes('virales')).slice(0, 8);
const complementaryProducts = allProducts.filter(p => p.categorySlugs?.includes('gadgets') || p.categorySlugs?.includes('general')).slice(0, 8);
---

<BaseLayout>
  <Prototipo 
    client:load 
    heroProducts={finalHeroProducts}
    trendingProducts={trendingProducts}
    viralProducts={viralProducts}
    complementaryProducts={complementaryProducts}
  />
</BaseLayout>

---
import NavbarWithCart from '../components/NavbarWithCart.jsx';
import Footer from '../components/Footer.jsx';
import WhatsAppButton from '../components/WhatsAppButton.jsx';
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Giopromet - Gadgets y Tecnología',
  description = 'Los gadgets más innovadores al mejor precio',
  image = '/og-image.png'
} = Astro.props as Props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <title>{title}</title>
  </head>
  <body>
    <!-- Navbar con su propio CartProvider (isla independiente en Astro) -->
    <NavbarWithCart client:load />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton client:load />
  </body>
</html>

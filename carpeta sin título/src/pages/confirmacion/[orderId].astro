---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ConfirmationPage from '../../components/ConfirmationPage.jsx';

interface Props {
  orderId: string;
}

const { orderId } = Astro.params as Props;
---

<BaseLayout title="Confirmación de Pedido | Giopromet" description="Tu pedido ha sido confirmado">
  <div class="pt-20">
    <ConfirmationPage client:load orderId={orderId} />
  </div>
</BaseLayout>
